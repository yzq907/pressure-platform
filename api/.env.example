# Mysterious Python 后端配置示例
# 复制为 .env 后按需修改

MYSTERIOUS_SERVER_PORT=4321
# 密码里若有特殊字符（@/#/?等）需做 URL 编码，例如 Test@123456 → Test%40123456
MYSTERIOUS_MYSQL_URL=mysql+asyncmy://root:Test%40123456@localhost:3306/mysterious?charset=utf8mb4
MYSTERIOUS_REDIS_URL=redis://localhost:6379/0
MYSTERIOUS_TOKEN_EXPIRE_HOURS=12
MYSTERIOUS_BCRYPT_ROUNDS=12
MYSTERIOUS_CORS_ORIGINS=*
MYSTERIOUS_UPLOAD_MAX_SIZE_MB=100
MYSTERIOUS_LOG_DIR=./logs
